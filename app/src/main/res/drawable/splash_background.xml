<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/splash_primary"
                android:endColor="@color/splash_secondary"
                android:angle="315" />
        </shape>
    </item>

    <!-- Soft radial glow behind the logo -->
    <item>
        <shape android:shape="oval">
            <size android:width="420dp" android:height="420dp" />
            <solid android:color="@color/splash_glow_soft" />
        </shape>
    </item>

    <!-- Accent blur blobs -->
    <item android:bottom="-120dp" android:right="-60dp">
        <shape android:shape="oval">
            <size android:width="320dp" android:height="320dp" />
            <gradient
                android:startColor="@color/splash_electric_blue"
                android:endColor="@android:color/transparent"
                android:angle="0" />
        </shape>
    </item>

    <item android:top="-160dp" android:left="-80dp">
        <shape android:shape="oval">
            <size android:width="360dp" android:height="360dp" />
            <gradient
                android:startColor="@color/splash_hot_pink"
                android:endColor="@android:color/transparent"
                android:angle="180" />
        </shape>
    </item>

    <!-- Subtle vignette -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00000000"
                android:centerColor="#33000000"
                android:endColor="#99000000"
                android:angle="90" />
        </shape>
    </item>
</layer-list>
