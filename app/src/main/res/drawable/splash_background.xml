<?xml version="1.0" encoding="utf-8"?>
<!-- Clean, minimal splash background with subtle gradient -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base gradient background - deep purple -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0A0015"
                android:centerColor="#120024"
                android:endColor="#0D001A"
                android:type="linear"
                android:angle="315" />
        </shape>
    </item>

    <!-- Subtle center glow for focus -->
    <item
        android:gravity="center">
        <shape android:shape="oval">
            <size android:width="400dp" android:height="400dp" />
            <gradient
                android:startColor="#157C3AED"
                android:endColor="#00000000"
                android:type="radial"
                android:gradientRadius="200dp" />
        </shape>
    </item>

</layer-list>
