<?xml version="1.0" encoding="utf-8"?>
<!--
    Widget configuration for Usage Tracker 2×2 widget.

    DESIGN DECISIONS:
    - minWidth/minHeight: 110dp = 2×2 cells on most launchers
    - updatePeriodMillis: 0 = Updates handled by WorkManager, not system
    - resizeMode: horizontal|vertical = Allows user flexibility
    - widgetCategory: home_screen = Standard home screen widget
    - previewLayout: Shows actual widget preview in picker

    BATTERY NOTE:
    updatePeriodMillis=0 means we control updates via WorkManager,
    avoiding battery drain from frequent system-triggered updates.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:targetCellWidth="2"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:previewLayout="@layout/widget_preview"
    android:initialLayout="@layout/widget_loading"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_description" />

